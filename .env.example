LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=300
OLLAMA_THINK=false
OLLAMA_NUM_PREDICT=2048
DEBUG_LLM_TRACE=false
LLM_TRACE_PREVIEW_CHARS=180

# Exa integration (MCP primary, API fallback)
# Set EXA_API_KEY to enable live Exa calls.
EXA_API_KEY=
EXA_MCP_URL=https://mcp.exa.ai/mcp
EXA_API_BASE_URL=https://api.exa.ai
EXA_TIMEOUT_S=45
EXA_NUM_RESULTS=1

# Browser MCP integration (optional; dummy fallback remains enabled)
PLAYWRIGHT_MCP_URL=
PLAYWRIGHT_MCP_API_KEY=
PLAYWRIGHT_MCP_TIMEOUT_S=60
# Override tool names if your MCP server uses different ones:
PLAYWRIGHT_MCP_OPEN_TOOL=browser_open_page
PLAYWRIGHT_MCP_EXTRACT_TOOL=browser_extract_facts
PLAYWRIGHT_MCP_CLOSE_TOOL=browser_close_page

# Switch to OpenAI by setting:
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional runtime settings
# DB_PATH=./runs.sqlite3
# MIN_AGENT_SCORE=70
# MAX_RETRIES_PER_AGENT=1
